{
    "name": "masmaleki/laravel-nexar-graphql",
    "description": "A Laravel package to interact with Nexar API using GraphQL",
    "type": "library",
    "license": "Apache-2.0",
    "version": "2.1.0",
    "require": {
        "php": "^8.3|^8.4",
        "guzzlehttp/guzzle": "^7.8",
        "illuminate/support": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "nesbot/carbon": "^2.72|^3.0"
    },
    "autoload": {
        "psr-4": {
            "NexarGraphQL\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "NexarGraphQL\\Providers\\NexarGraphQLServiceProvider"
            ],
            "aliases": {
                "NexarGraphQL": "NexarGraphQL\\Facades\\NexarGraphQL"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
